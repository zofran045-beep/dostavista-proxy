{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/calculate",
      "dest": "api/calculate.js"
    },
    {
      "src": "/api/create-order",
      "dest": "api/create-order.js"
    }
  ]
}